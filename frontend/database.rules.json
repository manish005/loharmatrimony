{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "conversations": {
      ".indexOn": ["participants"]
    },
    "messages": {
      ".indexOn": [".value"]
    },
    "siteConfig": {
      ".read": "true",
      ".write": "auth != null && auth.token.email != null && auth.token.email.toLowerCase().matches('.*admin.*')"
    }
  }
}
